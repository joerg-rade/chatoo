{
  "servers": {
    "openapi": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@ivotoby/openapi-mcp-server",
        "--stdio",
        "--openapi-spec",
        "http://app:8080/restful/swagger/private",
        "--api-base-url",
        "http://app:8080/restful",
        "--auth",
        "Basic c3ZlbjpwYXNz"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/tmp"
      ]
    }
  }
}
